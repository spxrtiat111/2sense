#!/usr/bin/env bash
# Thin wrapper so the skill / you can call the CLI without managing the venv.
# Usage: bin/ee doc --ping   |   bin/ee prep <path-or-url>   |   bin/ee show <slug>
set -euo pipefail
export PATH="$HOME/.local/bin:$PATH"
PROJECT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
exec uv run --project "$PROJECT_DIR" ee "$@"
